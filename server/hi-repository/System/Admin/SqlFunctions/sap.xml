<!--  SAP HANA specific functions  (start)-->


	
	<function group="SAP HANA specific" returns="text">
        <key>sql.text.LAST_DAY</key>
        <value>LAST_DAY</value>
        <signature><![CDATA[LAST_DAY(${value})]]></signature>
        <parameters>
            <parameter column="true" name="value"/>
        </parameters>
        <description>Returns the date of the last day of the month that contains the date</description>
    </function>
	
	
	 <function group="SAP HANA specific" returns="dateTime">
        <key>sql.text.GENERATE_PASSWORD</key>
        <value>GENERATE_PASSWORD</value>
        <signature><![CDATA[GENERATE_PASSWORD(${length})]]></signature>
        <parameters>
            <parameter defaultValue="6" name="length"/>
        </parameters>
        <description>It returns a generated password of 16 characters</description>
    </function>
	
</functions>