<?xml version="1.0" encoding="utf-8" ?>
<services>
    <!-- Without the mandatory attribute the json library is missing the first child node. So, any type should always have the mandatory attribute. -->
    <!-- There should be only one node for each feature type in a single xml file. -->
    <!-- The type(core) represents a feature-->
    <description>Configurable services of HDI</description>
    <core mandatory="true">
        <!-- Acutal serviceType -->
        <dataSource>
            <!-- The service implementation -->
            <fileOperationOverNetwork class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <loadDriver class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <updateDrillConfig class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <deleteUploadedDrillFiles class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"  access="ROLE_ADMIN"/>
            <drillCsvDatasource class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <drill class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <drillConfig class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"  access="ROLE_ADMIN"/>

            <sheduledReports class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <listing class="com.helicalinsight.datasource.DataSourceDelete" access="ROLE_ADMIN"/>
            <shutdown class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <cachedDS class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <cacheStats class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <abortWorker class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"  access="ROLE_ADMIN"/>
            <delete class="com.helicalinsight.datasource.DataSourceDelete" access="ROLE_ADMIN"/>
            <read class="com.helicalinsight.datasource.DataSourceReader" access="ROLE_ADMIN"/>
            <write class="com.helicalinsight.adhoc.services.DataSourceWriter" access="ROLE_ADMIN"/>
            <update class="com.helicalinsight.adhoc.services.DataSourceUpdateHandler" access="ROLE_ADMIN"/>
            <test class="com.helicalinsight.adhoc.services.DataSourceConnectionTester" access="ROLE_ADMIN"/>
            <quickTest class="com.helicalinsight.datasource.QuickConnectionTest" access="ROLE_ADMIN"/>
            <reportFiles class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>

        </dataSource>
        <!-- To update any resource that has security and share feature -->
        <share mandatory="true">
            <fetchInfo class="com.helicalinsight.resourcesecurity.ShareService"/>
            <update class="com.helicalinsight.resourcesecurity.ShareService"/>
            <retrieveSharedInfo class="com.helicalinsight.resourcesecurity.ShareService"/>
        </share>
    </core>
    <!-- A type that represents a feature adhoc-->
    <adhoc mandatory="true">
        <query mandatory="true">
            <discover class="com.helicalinsight.nlp.NlqaService"/>
            <cancelQuery class="com.helicalinsight.adhoc.services.CustomScriptService"/>
            <queryDetails class="com.helicalinsight.adhoc.services.CustomScriptService" access="ROLE_ADMIN"/>
        </query>
        <metadata mandatory="true">

            <fetchMetadata class="com.helicalinsight.adhoc.services.MetadataService"/>
            <security class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <evaluateSecurity class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <saveView class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <sync class="com.helicalinsight.spark.SparkMetadataService"/>
            <retrieveJoins class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"  access="ROLE_ADMIN"/>

            <dumpCube class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <cachedConnectionStatus class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"  access="ROLE_ADMIN"/>
            <fetchAllCubes class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <fetchPhase class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>

            <get class="com.helicalinsight.adhoc.services.MetadataProvider"/>

            <update class="com.helicalinsight.adhoc.services.MetadataUpdateService" access="ROLE_ADMIN"/>
            <delete class="com.helicalinsight.adhoc.services.MetadataDeleteService"/>
            <deleteMetadata class="com.helicalinsight.adhoc.services.MetadataDeleteService"/>

            <cacheMetadata class="com.helicalinsight.adhoc.services.MetadataWorkflowService"/>


            <saveWorkflow class="com.helicalinsight.adhoc.services.MetadataWorkflowService" access="ROLE_ADMIN"/>

            <getFunctions class="com.helicalinsight.adhoc.services.FunctionsListService"/>
            <metadataWorkflow class="com.helicalinsight.adhoc.services.MetadataWorkflowService" workerBean="metadataRetrieval" serviceImplBean="autoTriggerCheckImpl" access="ROLE_ADMIN"/>
            <retrieveViewLabels class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <retrieveView class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>


            <getSecurity class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            

            <access class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>

            <fetchJoins class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <dialectInformation class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <fetchColumns class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
			<!--  new service  -->
			<listMetadataDump class= "com.helicalinsight.adhoc.services.MetadataDumpService" access="ROLE_ADMIN"/>
			<deleteDump class="com.helicalinsight.adhoc.services.MetadataDumpService" access="ROLE_ADMIN"/>
			<cancelDump class="com.helicalinsight.adhoc.services.MetadataDumpService" access="ROLE_ADMIN"/>
			<getMetadataForEdit class="com.helicalinsight.adhoc.services.MetadataProvider"  access="ROLE_ADMIN"/>			
        </metadata>
		<cube mandatory="true">
			<update class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"  classifier="db.generic, db.calcite, db.workflow,  db.noSql"/>
			<getCube class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"  classifier="db.generic, db.calcite, db.workflow,  db.noSql"/>
        </cube>
        <report mandatory="true">
            <visualize class="com.helicalinsight.adhoc.services.VisualizationService"/>
            <generateQuery class="com.helicalinsight.adhoc.services.QueryGeneratorService"/>
            <executeQuery class="com.helicalinsight.adhoc.services.QueryExecutorService"/>
            <fetchData class="com.helicalinsight.adhoc.services.QueryGeneratorAndExecutorService"/>
            <fetchDataSpark class="com.helicalinsight.adhoc.services.QueryGeneratorAndExecutorService"/>
            <saveReport class="com.helicalinsight.adhoc.services.AdhocReportService"/>
            <deleteReport class="com.helicalinsight.adhoc.services.ReportDeleteService"/>

            <getReport class="com.helicalinsight.adhoc.services.VisualizationService"/>
            <!-- To fix the bug related to being able to edit a shared adhoc report, this new service is created -->
            <getReportForEdit class="com.helicalinsight.adhoc.services.VisualizationService"/>
			<getDerivedFormdata class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
			<fetchFilePrcoessStatus class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
        </report>
		<customScript mandatory="true">
            <search class="com.helicalinsight.adhoc.services.CustomScriptService"/>
            <getSnippets class="com.helicalinsight.adhoc.services.CustomScriptService"/>
            <save class="com.helicalinsight.adhoc.services.CustomScriptService"/>
            <update class="com.helicalinsight.adhoc.services.CustomScriptService"/>
            <fetch class="com.helicalinsight.adhoc.services.CustomScriptService"/>
            <delete class="com.helicalinsight.adhoc.services.CustomScriptService"/>

        </customScript>
        <threadpool mandatory="true">
            <queryManager class="com.helicalinsight.adhoc.services.CustomScriptService"/>
        </threadpool>
        <recycleBin mandotory="true">
        	<recycle class="com.helicalinsight.adhoc.services.RecycleBinService" access="ROLE_ADMIN"/>
        </recycleBin>
        <owner mandotory="true">
        	<change class="com.helicalinsight.adhoc.services.OwnershipChangeService" access="ROLE_ADMIN"/>
        </owner>
    </adhoc>
    <hcr mandatory="true">
        <report mandatory="true">
            <executeReportQuery class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <generateReport class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <saveReportState class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <fetchReportState class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <deleteReportState class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>

        </report>
    </hcr>
    <dashboard mandatory="true">
        <efwdd mandatory="true">
            <designer class="com.helicalinsight.adhoc.services.DashboardDesignerService"/>
            <fetch class="com.helicalinsight.adhoc.services.DashboardDesignerService"/>
            <delete class="com.helicalinsight.adhoc.services.DashboardDesignerService"/>
        </efwdd>
        <efwce mandatory="true">
            <designer class="com.helicalinsight.adhoc.services.DashboardDesignerService"/>
            <fetch class="com.helicalinsight.adhoc.services.DashboardDesignerService"/>
            <delete class="com.helicalinsight.adhoc.services.DashboardDesignerService"/>
        </efwce>
    </dashboard>
    <content mandatory="true">
        <static mandatory="true">
            <getContents class="com.helicalinsight.export.ExportService"/>
        </static>
    </content>
    <print mandatory="true">
        <export mandatory="true">
            <getTemplateList class="com.helicalinsight.export.ExportService"/>
            <getExportSettings class="com.helicalinsight.export.ExportService"/>
            <getTemplate class="com.helicalinsight.export.ExportService"/>
            <deleteTemplate class="com.helicalinsight.export.ExportService"/>
            <saveTemplate class="com.helicalinsight.export.ExportService"/>
            <getContents class="com.helicalinsight.export.ExportService"/>
            <xls class="com.helicalinsight.export.ExportService"/>
            <phantomActions class="com.helicalinsight.export.ExportService"/>
        </export>
    </print>
    <monitor mandatory="true">
        <scheduling mandatory="true">
            <schedule class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <migrateSchedules class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <generateCron class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
        </scheduling>
        <cache mandatory="true">
            <updateConfiguration class="com.helicalinsight.admin.management.ResourceManagerService"  access="ROLE_ADMIN"/>
            <size class="com.helicalinsight.admin.management.ResourceManagerService" access="ROLE_ADMIN"/>
            <delete class="com.helicalinsight.admin.management.ResourceManagerService" access="ROLE_ADMIN"/>
            <dump class="com.helicalinsight.admin.management.ResourceManagerService" access="ROLE_ADMIN"/>
            <clean class="com.helicalinsight.admin.management.ResourceManagerService" access="ROLE_ADMIN"/>
            <refresh class="com.helicalinsight.admin.management.ResourceManagerService" access="ROLE_ADMIN"/>

        </cache>
		 <saml mandatory="true">
			<saveMD class="com.helicalinsight.admin.management.ResourceManagerService"  access="ROLE_ADMIN"/>
			<editMD class="com.helicalinsight.admin.management.ResourceManagerService"  access="ROLE_ADMIN"/>
        </saml>
        <system mandatory="true">
            <systemInfo class="com.helicalinsight.admin.management.ResourceManagerService" access="ROLE_ADMIN"/>
            <tempFile class="com.helicalinsight.admin.management.ResourceManagerService" access="ROLE_ADMIN"/>
            <log class="com.helicalinsight.admin.management.ResourceManagerService" access="ROLE_ADMIN"/>
            <readWrite class="com.helicalinsight.admin.management.ResourceManagerService" access="ROLE_ADMIN"/>
            <list class="com.helicalinsight.admin.management.ResourceManagerService" access="ROLE_ADMIN"/>
            <closePlugin class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <availablePlugins class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <loadedPlugins class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <reportStats class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <datasourceCount class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <diskSpace class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <management class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <customWatcher class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <deletePlugin class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <readProperty class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <noSqlConfig class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"  access="ROLE_ADMIN"/>
            <updateNoSql class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <mailStats class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <llmUsageStats class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" access="ROLE_ADMIN"/>
            <release class="com.helicalinsight.efw.services.ReleaseNoteService" />
        </system>
    </monitor>
    <instantbi mandatory="true">
        <instant mandatory="true">
            <saveReport class="com.helicalinsight.adhoc.services.AdhocReportService"/>
            <getReportForEdit class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <getReport class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <saveAiAgent class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" />
            <getAiAgentForEdit class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" />
            <getAgent class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" />
            <generateAgent class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation" />
        </instant>

    </instantbi>
    <hwf mandatory="true">
        <hwfFile mandatory="true">
            <create class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <fetch class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <delete class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <types class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
        </hwfFile>
    </hwf>
    <util mandatory="true">
        <io mandatory="true">
            <getExtensions class="com.helicalinsight.admin.management.FileExtensionService"/>
            <getTypesDetails class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <imageService class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <previewEmail class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
        </io>
        <fileBrowser mandatory="true">
            <search class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
            <refreshFileBrowser class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
        </fileBrowser>
    </util>
    <!-- <import>
        <xml name="exampleImportServices.xml"/>
    </import> -->

    <common mandatory="true">
        <!-- Acutal serviceType -->
        <abort mandatory="true">
            <abortRequest class="com.helicalinsight.efw.serviceframework.GenericServiceImplementation"/>
        </abort>
    </common>
</services>




