{
  "business_metrics": [
    {
      "metric": "canceled_meetings",
      "description": "Total number of meetings marked as canceled",
      "formula": "COUNT(meeting_details.meeting_id)",
      "filter": "meeting_details.meet_cancellation_status = 'Yes'",
      "tables": [
        "meeting_details"
      ]
    },
    {
      "metric": "meeting_cancellation_rate",
      "description": "Percentage of all meetings that were canceled",
      "formula": "COUNT(CASE WHEN meeting_details.meet_cancellation_status = 'Yes' THEN 1 END) * 100.0 / COUNT(meeting_details.meeting_id)",
      "tables": [
        "meeting_details"
      ]
    },
    {
      "metric": "meetings_per_employee",
      "description": "Average number of meetings conducted per employee",
      "formula": "COUNT(meeting_details.meeting_id) / COUNT(DISTINCT employee_details.employee_id)",
      "tables": [
        "employee_details",
        "meeting_details"
      ]
    },
    {
      "metric": "successful meetings",
      "description": "Total number of meetings completed without cancellation",
      "formula": "COUNT(meeting_details.meeting_id)",
      "filter": "meeting_details.meet_cancellation_status = 'No'",
      "tables": [
        "meeting_details"
      ]
    }
  ],
