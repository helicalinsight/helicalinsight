  "scripts": {
    "start": "node --max_old_space_size=5096 scripts/start",
    "build": "node --max_old_space_size=5096 scripts/build",
    "test": "node scripts/test.js --max_old_space_size=8096 --watchAll=false --silent",
    "test:dev": "node scripts/test.js",
    "analyze": "source-map-explorer 'build/static/js/*.js'",
    "proxy": "nodemon proxy",
    "muze": "node muze.config",
    "start18": "node --max_old_space_size=5096 --openssl-legacy-provider scripts/start",
    "test:debug": "node --expose-gc --no-compilation-cache scripts/test.js --logHeapUsage --runInBand"
  },
  "nodemonConfig": {
    "ignore": [
      "src/*",
      "package.json",
      "client/*"
    ]
  },
  "jest": {
    "roots": [
      "<rootDir>/src"
    ],
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts"
    ],
    "setupFiles": [
      "react-app-polyfill/jsdom",
      "jsdom-worker"
    ],
    "setupFilesAfterEnv": [],
    "testMatch": [
      "<rootDir>/src/test/**/*.{spec,test}.{js,jsx,ts,tsx}",
      "<rootDir>/src/utils/**/*.{spec,test}.{js,jsx,ts,tsx}"
    ],
    "reporters": [
      "default",
      "jest-stare"
    ],
    "testResultsProcessor": "./node_modules/jest-stare",
    "watchPathIgnorePatterns": [
      ".*jest-stare.*\\.js"
    ],
    "testEnvironment": "jsdom",
    "testRunner": "<rootDir>node_modules/jest-circus/runner.js",
    "globalTeardown": "<rootDir>/src/test/globalTearDown.js",
    "transform": {
      "^.+\\.(js|jsx|mjs|cjs|ts|tsx)$": "<rootDir>/config/jest/babelTransform.js",
      "^.+\\.css$": "<rootDir>/config/jest/cssTransform.js",
      "^(?!.*\\.(js|jsx|mjs|cjs|ts|tsx|css|json)$)": "<rootDir>/config/jest/fileTransform.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!@ngrx|(?!deck.gl)|ng-dynamic)"
    ],
    "modulePaths": [],
    "moduleNameMapper": {
      "^react-native$": "react-native-web",
      "^.+\\.module\\.(css|sass|scss)$": "identity-obj-proxy",
      "^deepdash-es$": "<rootDir>node_modules/deepdash-es"
    },
    "moduleFileExtensions": [
      "web.js",
      "js",
      "web.ts",
      "ts",
      "web.tsx",
      "tsx",
      "json",
      "web.jsx",
      "jsx",
      "node"
    ],
    "watchPlugins": [
      "jest-watch-typeahead/filename",
      "jest-watch-typeahead/testname"
    ],
    "resetMocks": true,
    "clearMocks": true,
    "timers": "fake"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/plugin-proposal-optional-chaining": "^7.21.0",
    "@babel/plugin-transform-nullish-coalescing-operator": "^7.27.1",
    "@storybook/addon-actions": "6.4.9",
    "@storybook/addon-essentials": "6.4.9",
    "@storybook/addon-links": "6.4.9",
    "@storybook/node-logger": "6.4.9",
    "@storybook/preset-create-react-app": "3.2.0",
    "@storybook/react": "6.4.9",
    "@testing-library/jest-dom": "^5.16.5",
    "babel-plugin-transform-remove-console": "6.9.4",
    "copy-webpack-plugin": "5.1.1",
    "deepdash-es": "^5.3.9",
    "jsdom-worker": "^0.3.0",
    "react-app-rewired": "2.1.11",
    "react-error-overlay": "6.0.9"
  },
  "babel": {
    "presets": [
      "react-app"
    ]
  }
}
