# Helical Insight — local development environment
# Copy to .env and adjust as needed.

# Host IP used in setting.xml BaseUrl (Docker backend)
HOST_IP=localhost

# Install Chrome in backend container (set true for export/PDF testing)
INSTALL_CHROME=false

# PostgreSQL (docker-compose.dev.yml)
POSTGRES_USER=hiuser
POSTGRES_PASSWORD=hiuser
POSTGRES_DB=hice

# Backend URL for native client dev (CRA proxy)
BACKEND_URL=http://localhost:8080

# Tomcat context path (WAR is deployed as hi-ce.war)
CONTEXT_PATH=hi-ce
