# HelicalBI Docker Compose — copy to ".env" and edit (this file is committed).
# PowerShell: Copy-Item .env.example .env
# Bash:       cp .env.example .env

# stub = deterministic LLM tests (no model API). live = real LLMManager (+ OpenAI for GEval when used).
HELICALBI_LLM_MODE=stub

# For live mode + OpenAI GEval judge only; leave empty for stub.
OPENAI_API_KEY=

# Service runtime (use HELICALBI_ENV=dev for local debug)
HELICALBI_ENV=production
HOST=0.0.0.0
PORT=8000
WEB_CONCURRENCY=4
FLASK_DEBUG=0
